# Minimal kernel config fragment for vmm-demo
# Apply on top of tinyconfig: make tinyconfig && scripts/kconfig/merge_config.sh .config THIS_FILE

# --- 64-bit x86 ---
CONFIG_64BIT=y

# --- Execute userspace binaries ---
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# --- TTY subsystem + serial console ---
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# --- Initramfs (gzipped cpio) ---
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# --- Filesystems needed by init script ---
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y

# --- Kernel features needed for a usable shell ---
CONFIG_PRINTK=y
CONFIG_MULTIUSER=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_UNIX=y
CONFIG_FILE_LOCKING=y
CONFIG_INOTIFY_USER=y
CONFIG_POSIX_TIMERS=y
CONFIG_SHMEM=y

# --- Don't need these ---
# CONFIG_MODULES is not set
# CONFIG_NETWORKING is not set
# CONFIG_BLOCK is not set
# CONFIG_SUSPEND is not set
# CONFIG_HIBERNATION is not set
